# Copy to .env and fill in. Never commit the real .env.

# Anthropic API key for the LLM foresight-briefing layer (optional).
# The rest of the platform runs fully without it.
ANTHROPIC_API_KEY=

# Model used by the insight layer.
AEROFORESIGHT_LLM_MODEL=claude-opus-4-8

# Where the pipeline writes datasets / model artifacts.
AEROFORESIGHT_DATA_DIR=data
AEROFORESIGHT_ARTIFACT_DIR=artifacts
